@model LocationVoiture.Core.Models.ContactMessage
@{
    ViewData["Title"] = "Contactez-nous";
}

<div class="hero-section" style="height: 40vh; min-height: 300px;">
    <div class="container text-center hero-content">
        <h1 class="hero-title mb-3">Une Question ?</h1>
        <p class="hero-subtitle">Notre équipe est là pour vous répondre 24/7.</p>
    </div>
</div>

<div class="container" style="margin-top: -80px; position: relative; z-index: 10;">
    <div class="row g-4">
        <!-- Contact Info Card -->
        <div class="col-lg-5">
            <div class="auth-card h-100 p-4 shadow-strong" style="background: var(--c-night); backdrop-filter: blur(10px);">
                <div class="mb-5">
                    <h2 class="text-white mb-4">Infos Contact</h2>
                    <div class="d-flex align-items-center mb-4">
                        <div class="social-icon" style="min-width: 50px; min-height: 50px; font-size: 1.2rem;">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="text-white mb-1">Notre Agence</h5>
                            <p class="text-muted mb-0">123 Avenue des Champs, Paris, France</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-4">
                        <div class="social-icon" style="min-width: 50px; min-height: 50px; font-size: 1.2rem;">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="text-white mb-1">Téléphone</h5>
                            <p class="text-muted mb-0">+33 1 23 45 67 89</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-4">
                        <div class="social-icon" style="min-width: 50px; min-height: 50px; font-size: 1.2rem;">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="text-white mb-1">Email</h5>
                            <p class="text-muted mb-0">contact@premiumauto.com</p>
                        </div>
                    </div>
                </div>
                <div class="mt-auto">
                     <h5 class="text-white mb-3">Suivez-nous</h5>
                     <div class="d-flex gap-2">
                        <a href="#" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-linkedin-in"></i></a>
                     </div>
                </div>
            </div>
        </div>

        <!-- Form Card -->
        <div class="col-lg-7">
            <div class="auth-card p-5 shadow-strong">
                <h2 class="section-title mb-4" style="text-align: left; margin-bottom: 2rem;">Envoyez un message</h2>
                
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success mb-4">
                        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    </div>
                }

                <form asp-action="SendMessage" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="Name" class="form-control form-control-custom" placeholder="Votre Nom">
                                <label asp-for="Name" class="form-label">Votre Nom</label>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                             <div class="form-floating">
                                <input asp-for="Email" class="form-control form-control-custom" placeholder="name@example.com">
                                <label asp-for="Email" class="form-label">Email</label>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Subject" class="form-control form-control-custom" placeholder="Sujet">
                        <label asp-for="Subject" class="form-label">Sujet</label>
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Message" class="form-control form-control-custom" style="height: 150px" placeholder="Votre message"></textarea>
                        <label asp-for="Message" class="form-label">Votre message</label>
                        <span asp-validation-for="Message" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-hero w-100">
                        Envoyer le message <i class="fas fa-paper-plane ms-2"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
