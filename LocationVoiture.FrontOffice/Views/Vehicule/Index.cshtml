@model IEnumerable<LocationVoiture.Core.Models.Vehicule>

@{
    ViewData["Title"] = "Notre Collection";
    var types = ViewBag.AllTypes as IEnumerable<LocationVoiture.Core.Models.TypeVehicule>;
    var selectedTypes = ViewBag.SelectedTypes as List<int> ?? new List<int>();
    var minPrice = ViewBag.MinPrice as decimal? ?? 0;
    var maxPrice = ViewBag.MaxPrice as decimal? ?? 1000;
}

<style>
    /* Sidebar Styles */
    .filter-sidebar {
        background: var(--card-bg);
        border-radius: 16px;
        padding: 25px;
        position: sticky;
        top: 100px;
        border: 1px solid var(--border-color);
    }
    .filter-title {
        color: var(--c-gold);
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .filter-section {
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border-color);
    }
    .filter-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }
    .type-checkbox {
        display: flex;
        align-items: center;
        padding: 10px 12px;
        margin-bottom: 8px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
        background: var(--body-bg);
    }
    .type-checkbox:hover {
        background: rgba(201, 164, 76, 0.1);
    }
    .type-checkbox input {
        width: 18px;
        height: 18px;
        accent-color: var(--c-gold);
        margin-right: 12px;
    }
    .type-checkbox label {
        flex: 1;
        cursor: pointer;
        margin: 0;
    }
    .type-count {
        background: var(--c-gold);
        color: var(--c-night);
        font-size: 0.75rem;
        padding: 2px 8px;
        border-radius: 10px;
        font-weight: 600;
    }
    .price-inputs {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
    }
    .price-inputs input {
        width: 100%;
        background: var(--body-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 10px 12px;
        color: var(--text-color);
    }
    .price-inputs input:focus {
        border-color: var(--c-gold);
        outline: none;
    }
    .btn-filter {
        background: linear-gradient(135deg, var(--c-gold), #d4a528);
        color: var(--c-night);
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 600;
        width: 100%;
        cursor: pointer;
        transition: all 0.3s;
    }
    .btn-filter:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(201, 164, 76, 0.3);
    }
    .btn-reset {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border-color);
        padding: 10px 20px;
        border-radius: 8px;
        width: 100%;
        margin-top: 20px;
        cursor: pointer;
        transition: all 0.2s;
        display: block;
        text-align: center;
        text-decoration: none;
    }
    .btn-reset:hover {
        border-color: var(--c-gold);
        color: var(--c-gold);
        text-decoration: none;
    }
    .results-count {
        background: var(--card-bg);
        border-radius: 12px;
        padding: 15px 20px;
        margin-bottom: 25px;
        border: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
</style>

<!-- PAGE HEADER -->
<div class="hero-section" style="min-height: 40vh; display: flex; align-items: center;">
    <div class="container text-center">
        <span class="badge mb-3">Collection Exclusive</span>
        <h1 class="hero-title">Notre Flotte</h1>
        <p class="hero-subtitle mx-auto" style="max-width: 600px;">
            Explorez notre sélection de véhicules d'exception
        </p>
    </div>
</div>

<div class="container" style="margin-top: -40px; position: relative; z-index: 10; margin-bottom: 60px;">
    <div class="row">
        <!-- SIDEBAR FILTERS -->
        <div class="col-lg-3 mb-4">
            <form asp-action="Index" method="get" id="filterForm">
                <div class="filter-sidebar">
                    
                    <!-- Search -->
                    <div class="filter-section">
                        <div class="filter-title">
                            <i class="fas fa-search"></i> Recherche
                        </div>
                        <input type="text" name="searchString" class="form-control form-control-custom" 
                               placeholder="Marque ou modèle..." value="@ViewBag.CurrentSearch">
                    </div>

                    <!-- Types Filter -->
                    <div class="filter-section">
                        <div class="filter-title">
                            <i class="fas fa-car"></i> Catégories
                        </div>
                        @if (types != null)
                        {
                            @foreach (var type in types)
                            {
                                var count = Model.Count(v => v.TypeVehiculeID == type.TypeVehiculeID);
                                var isChecked = selectedTypes.Contains(type.TypeVehiculeID);
                                <div class="type-checkbox">
                                    <input type="checkbox" name="typeIds" value="@type.TypeVehiculeID" 
                                           id="type_@type.TypeVehiculeID" @(isChecked ? "checked" : "")>
                                    <label for="type_@type.TypeVehiculeID">@type.Nom</label>
                                    <span class="type-count">@count</span>
                                </div>
                            }
                        }
                    </div>

                    <!-- Price Range -->
                    <div class="filter-section">
                        <div class="filter-title">
                            <i class="fas fa-euro-sign"></i> Prix par jour
                        </div>
                        <div class="price-inputs">
                            <input type="number" name="minPrice" placeholder="Min €" value="@(minPrice > 0 ? minPrice : "")">
                            <input type="number" name="maxPrice" placeholder="Max €" value="@(maxPrice < 1000 ? maxPrice : "")">
                        </div>
                    </div>

                    <!-- Filter Buttons -->
                    <button type="submit" class="btn-filter">
                        <i class="fas fa-filter me-2"></i> Appliquer les filtres
                    </button>
                    <a asp-action="Index" class="btn-reset">
                        <i class="fas fa-undo me-2"></i> Réinitialiser
                    </a>
                </div>
            </form>
        </div>

        <!-- VEHICLES GRID -->
        <div class="col-lg-9">
            <!-- Results Count -->
            <div class="results-count">
                <span>
                    <strong class="gold">@Model.Count()</strong> véhicule(s) trouvé(s)
                </span>
                <span class="text-muted small">
                    <i class="fas fa-th-large me-1"></i> Vue grille
                </span>
            </div>

            <div class="row g-4">
                @foreach (var vehicule in Model)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="car-card h-100 fade-in-up">
                            <div class="car-img-wrapper position-relative">
                                <img src="@(string.IsNullOrEmpty(vehicule.ImageURL) ? "/images/car1.png" : vehicule.ImageURL)" 
                                     alt="@vehicule.Modele" class="img-fluid w-100 h-100" style="object-fit:cover;">
                                <span class="position-absolute top-0 end-0 m-3 badge" 
                                      style="background: rgba(10,26,47,0.9); color: var(--c-gold); border: 1px solid var(--c-gold);">
                                    @vehicule.TypeVehicule.Nom
                                </span>
                                @if (vehicule.QuantiteDisponible > 0)
                                {
                                    <span class="position-absolute top-0 start-0 m-3 badge" 
                                          style="background: rgba(34, 197, 94, 0.9); color: white;">
                                        <i class="fas fa-check-circle me-1"></i> @vehicule.QuantiteDisponible dispo
                                    </span>
                                }
                                else
                                {
                                    <span class="position-absolute top-0 start-0 m-3 badge" 
                                          style="background: rgba(239, 68, 68, 0.9); color: white;">
                                        <i class="fas fa-ban me-1"></i> Indisponible
                                    </span>
                                }
                                <!-- Image count badge if multiple images -->
                                @if (vehicule.Images?.Count > 1)
                                {
                                    <span class="position-absolute bottom-0 end-0 m-3 badge" 
                                          style="background: rgba(0,0,0,0.7); color: white;">
                                        <i class="fas fa-images me-1"></i> @vehicule.Images.Count photos
                                    </span>
                                }
                            </div>
                            <div class="car-details">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="car-title mb-0">@vehicule.Marque @vehicule.Modele</h5>
                                </div>
                                
                                <div class="d-flex justify-content-between text-muted small mb-3">
                                    <span><i class="fas fa-calendar-alt gold me-1"></i> @vehicule.Annee</span>
                                    <span><i class="fas fa-palette gold me-1"></i> @(vehicule.Couleur ?? "N/A")</span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center pt-3 border-top" 
                                     style="border-color: var(--border-color) !important;">
                                    <span class="car-price">
                                        @vehicule.PrixJournee.ToString("N0") €
                                        <small>/jour</small>
                                    </span>
                                    <a asp-action="Details" asp-route-id="@vehicule.VehiculeID" class="btn btn-sm btn-hero">
                                        Voir <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (!Model.Any())
                {
                    <div class="col-12">
                        <div class="card-luxury text-center py-5">
                            <div class="icon-circle mx-auto mb-4" style="width: 100px; height: 100px; font-size: 2.5rem;">
                                <i class="fas fa-car-side"></i>
                            </div>
                            <h3 class="mb-3">Aucun véhicule trouvé</h3>
                            <p class="text-muted mb-4">Essayez de modifier vos critères de recherche.</p>
                            <a asp-action="Index" class="btn btn-outline-gold">
                                <i class="fas fa-undo me-2"></i> Réinitialiser les filtres
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
