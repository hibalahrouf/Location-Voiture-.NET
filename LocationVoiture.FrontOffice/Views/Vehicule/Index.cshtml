@model IEnumerable<LocationVoiture.Core.Models.Vehicule>

@{
    ViewData["Title"] = "Notre Collection";
}

<!-- PAGE HEADER -->
<div class="hero-section" style="min-height: 45vh; display: flex; align-items: center;">
    <div class="container text-center">
        <span class="badge mb-3">Collection Exclusive</span>
        <h1 class="hero-title">Notre Flotte</h1>
        <p class="hero-subtitle mx-auto" style="max-width: 600px;">
            Explorez notre sélection de véhicules d'exception et trouvez le compagnon idéal pour votre prochaine aventure.
        </p>
    </div>
</div>

<div class="container" style="margin-top: -60px; position: relative; z-index: 10; margin-bottom: 60px;">
    
    <!-- FILTER CARD -->
    <div class="card-luxury p-4 mb-5">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label text-muted">
                        <i class="fas fa-search gold me-1"></i> Recherche
                    </label>
                    <input type="text" name="searchString" class="form-control form-control-custom" 
                           placeholder="Marque ou modèle..." value="@ViewBag.CurrentSearch">
                </div>
                <div class="col-md-5">
                    <label class="form-label text-muted">
                        <i class="fas fa-filter gold me-1"></i> Catégorie
                    </label>
                    <select name="typeId" class="form-select form-control-custom" asp-items="@ViewBag.Types">
                        <option value="">-- Toutes les catégories --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-hero w-100">
                        Filtrer
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- VEHICLES GRID -->
    <div class="row g-4">
        @foreach (var vehicule in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="car-card h-100 fade-in-up">
                    <div class="car-img-wrapper position-relative">
                        <img src="@(string.IsNullOrEmpty(vehicule.ImageURL) ? "/images/car1.png" : vehicule.ImageURL)" 
                             alt="@vehicule.Modele" class="img-fluid w-100 h-100" style="object-fit:cover;">
                        <span class="position-absolute top-0 end-0 m-3 badge" 
                              style="background: rgba(10,26,47,0.9); color: var(--c-gold); border: 1px solid var(--c-gold);">
                            @vehicule.TypeVehicule.Nom
                        </span>
                        @if (vehicule.Disponible)
                        {
                            <span class="position-absolute top-0 start-0 m-3 badge" 
                                  style="background: rgba(34, 197, 94, 0.9); color: white;">
                                <i class="fas fa-check-circle me-1"></i> Disponible
                            </span>
                        }
                    </div>
                    <div class="car-details">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="car-title mb-0">@vehicule.Marque @vehicule.Modele</h5>
                        </div>
                        
                        <div class="d-flex justify-content-between text-muted small mb-3">
                            <span><i class="fas fa-calendar-alt gold me-1"></i> @vehicule.Annee</span>
                            <span><i class="fas fa-fingerprint gold me-1"></i> @vehicule.Immatriculation</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top" 
                             style="border-color: var(--border-color) !important;">
                            <span class="car-price">
                                @vehicule.PrixJournee.ToString("C0")
                                <small>/jour</small>
                            </span>
                            <a asp-action="Details" asp-route-id="@vehicule.VehiculeID" class="btn btn-sm btn-hero">
                                Réserver <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="card-luxury text-center py-5">
                    <div class="icon-circle mx-auto mb-4" style="width: 100px; height: 100px; font-size: 2.5rem;">
                        <i class="fas fa-car-side"></i>
                    </div>
                    <h3 class="mb-3">Aucun véhicule trouvé</h3>
                    <p class="text-muted mb-4">Essayez de modifier vos critères de recherche.</p>
                    <a asp-action="Index" class="btn btn-outline-gold">
                        <i class="fas fa-undo me-2"></i> Réinitialiser les filtres
                    </a>
                </div>
            </div>
        }
    </div>
</div>
