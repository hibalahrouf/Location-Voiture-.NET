@model IEnumerable<LocationVoiture.Core.Models.Vehicule>

@{
    ViewData["Title"] = "Notre Collection";
}

<div class="hero-section" style="height: 40vh; min-height: 300px;">
    <div class="container text-center hero-content">
        <h1 class="hero-title mb-3">Explorez le Luxe</h1>
        <p class="hero-subtitle">Choisissez votre compagnon de route idéal.</p>
    </div>
</div>

<div class="container" style="margin-top: -80px; position: relative; z-index: 10;">
    
    <!-- Filter Bar -->
    <div class="auth-card p-4 mb-5" style="background: var(--card-bg); backdrop-filter: blur(10px);">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label text-muted">Recherche</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background: var(--input-bg); border-color: var(--input-border); color: var(--gold);"><i class="fas fa-search"></i></span>
                        <input type="text" name="searchString" class="form-control form-control-custom" placeholder="Marque ou modèle..." value="@ViewBag.CurrentSearch" style="border-left: none;">
                    </div>
                </div>
                <div class="col-md-5">
                    <label class="form-label text-muted">Catégorie</label>
                    <select name="typeId" class="form-select form-control-custom" asp-items="@ViewBag.Types">
                        <option value="">-- Toutes les catégories --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-search w-100">Filtrer</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Vehicles Grid -->
    <div class="row g-4">
        @foreach (var vehicule in Model)
        {
            <div class="col-md-4">
                <div class="car-card h-100">
                    <div class="car-img-wrapper position-relative">
                        <img src="@(string.IsNullOrEmpty(vehicule.ImageURL) ? "/images/car1.png" : vehicule.ImageURL)" alt="@vehicule.Modele" class="img-fluid w-100 h-100" style="object-fit:cover;">
                        <span class="position-absolute top-0 end-0 m-3 badge bg-dark text-gold border border-gold rounded-pill px-3 py-2">
                            @vehicule.TypeVehicule.Nom
                        </span>
                    </div>
                    <div class="car-details">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="car-title text-truncate">@vehicule.Marque @vehicule.Modele</h5>
                            <span class="car-price">@vehicule.PrixJournee.ToString("C0")<small class="text-muted fs-6">/jour</small></span>
                        </div>
                        
                        <div class="d-flex justify-content-between text-muted small mb-3">
                            <span><i class="fas fa-calendar-alt me-1 gold"></i> @vehicule.Annee</span>
                            <span><i class="fas fa-fingerprint me-1 gold"></i> @vehicule.Immatriculation</span>
                        </div>

                        <a asp-action="Details" asp-route-id="@vehicule.VehiculeID" class="btn btn-login w-100">
                            Réserver <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="display-1 text-muted mb-3"><i class="fas fa-car-crash"></i></div>
                <h3 class="text-muted">Aucun véhicule trouvé.</h3>
                <p class="text-muted">Essayez de modifier vos filtres.</p>
                <a asp-action="Index" class="btn btn-link gold">Voir tout le catalogue</a>
            </div>
        }
    </div>
</div>

