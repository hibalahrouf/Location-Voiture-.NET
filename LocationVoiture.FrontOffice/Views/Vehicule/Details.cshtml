@model LocationVoiture.Core.Models.Vehicule

@{
    ViewData["Title"] = $"{Model.Marque} {Model.Modele}";
}

<!-- HERO HEADER -->
<div class="position-relative w-100 d-flex align-items-center justify-content-center" style="min-height: 40vh; overflow: hidden; margin-top: -20px;">
    <!-- Background blurred image -->
    <div class="position-absolute w-100 h-100" 
         style="background: url('@(string.IsNullOrEmpty(Model.ImageURL) ? "/images/hero.png" : Model.ImageURL)') center/cover; filter: blur(8px) brightness(0.7); transform: scale(1.1);">
    </div>
    
    <!-- Gradient Overlay to blend with body -->
    <div class="position-absolute w-100 h-100" 
         style="background: linear-gradient(to bottom, rgba(10,26,47,0.4), var(--bg-body));">
    </div>

    <!-- Content -->
    <div class="container position-relative z-1 text-center mt-5">
        <span class="badge mb-3 float-anim text-uppercase" style="background: var(--c-gold); color: var(--c-night); letter-spacing: 2px;">
            @Model.TypeVehicule.Nom
        </span>
        <h1 class="display-3 fw-bold mb-2 fade-in-up" 
            style="color: var(--c-text-main); text-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            @Model.Marque <span class="gold">@Model.Modele</span>
        </h1>
        <div class="d-flex justify-content-center align-items-center gap-3 fade-in-up" style="animation-delay: 0.1s;">
            <div class="px-3 py-1 rounded-pill" style="background: var(--bg-card); border: 1px solid var(--border-color);">
                <i class="fas fa-calendar-alt gold me-2"></i>@Model.Annee
            </div>
            <div class="px-3 py-1 rounded-pill" style="background: var(--bg-card); border: 1px solid var(--border-color);">
                <i class="fas fa-palette gold me-2"></i>@Model.Couleur
            </div>
        </div>
    </div>
</div>

<div class="container pb-5" style="margin-top: -40px; position: relative; z-index: 2;">
    <div class="row g-4">
        
        <!-- LEFT COLUMN: Gallery & Info -->
        <div class="col-lg-8">
            <div class="card-luxury p-0 overflow-hidden shadow-strong reveal">
                
                <!-- Main Image Carousel -->
                @{
                    var allImages = new List<string>();
                    if (!string.IsNullOrEmpty(Model.ImageURL)) allImages.Add(Model.ImageURL);
                    if (Model.Images != null) allImages.AddRange(Model.Images.Select(i => i.ImagePath));
                    if (!allImages.Any()) allImages.Add("/images/car1.png");
                }
                
                <div id="vehicleCarousel" class="carousel slide" data-bs-ride="carousel">
                    <!-- Main Image -->
                    <div class="carousel-inner" style="max-height: 500px;">
                        @for (int i = 0; i < allImages.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@allImages[i]" alt="@Model.Modele - Image @(i+1)" 
                                     class="d-block w-100" style="height: 500px; object-fit: cover;">
                            </div>
                        }
                    </div>
                    
                    <!-- Navigation Arrows -->
                    @if (allImages.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#vehicleCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" style="background-color: rgba(10,26,47,0.5); border-radius: 50%; padding: 20px;"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#vehicleCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" style="background-color: rgba(10,26,47,0.5); border-radius: 50%; padding: 20px;"></span>
                        </button>
                    }
                </div>

                <!-- Thumbnails Bar -->
                @if (allImages.Count > 1)
                {
                    <div class="p-3 bg-light border-top d-flex gap-2 overflow-auto" style="background: var(--bg-card) !important; border-color: var(--border-color) !important;">
                        @for (int i = 0; i < allImages.Count; i++)
                        {
                            <img src="@allImages[i]" onclick="$('#vehicleCarousel').carousel(@i)"
                                 class="rounded cursor-pointer" 
                                 style="width: 80px; height: 60px; object-fit: cover; border: 2px solid var(--c-gold); opacity: 0.7; transition: 0.3s;"
                                 onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'">
                        }
                    </div>
                }
            </div>

            <!-- Specs Grid -->
            <div class="row g-3 mt-4 reveal" style="transition-delay: 0.1s;">
                <div class="col-md-3 col-6">
                    <div class="card-luxury p-3 text-center h-100 d-flex flex-column align-items-center justify-content-center shadow-sm">
                        <i class="fas fa-tachometer-alt gold fa-2x mb-2"></i>
                        <span class="small text-muted">Moteur</span>
                        <span class="fw-bold">V8 Turbo</span>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="card-luxury p-3 text-center h-100 d-flex flex-column align-items-center justify-content-center shadow-sm">
                        <i class="fas fa-cogs gold fa-2x mb-2"></i>
                        <span class="small text-muted">Transmission</span>
                        <span class="fw-bold">Automatique</span>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="card-luxury p-3 text-center h-100 d-flex flex-column align-items-center justify-content-center shadow-sm">
                        <i class="fas fa-gas-pump gold fa-2x mb-2"></i>
                        <span class="small text-muted">Carburant</span>
                        <span class="fw-bold">Essence</span>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="card-luxury p-3 text-center h-100 d-flex flex-column align-items-center justify-content-center shadow-sm">
                        <i class="fas fa-chair gold fa-2x mb-2"></i>
                        <span class="small text-muted">Places</span>
                        <span class="fw-bold">4 Personnes</span>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="card-luxury p-5 mt-4 shadow-strong reveal" style="transition-delay: 0.2s;">
                <h4 class="mb-4" style="color: var(--c-text-main);">
                    <i class="fas fa-quote-left gold me-2"></i>L'Expérience
                </h4>
                <p class="lead" style="color: var(--c-muted); line-height: 1.8;">
                    Montez à bord de cette <strong>@Model.Marque @Model.Modele</strong> et ressentez l'alliance parfaite entre luxe et performance. 
                    Chaque détail a été pensé pour votre confort. Que ce soit pour un événement spécial, un voyage d'affaires ou simplement le plaisir de conduire, 
                    ce véhicule saura dépasser vos attentes.
                </p>
                <div class="mt-4 pt-4 border-top" style="border-color: var(--border-color) !important;">
                    <h5 class="mb-3">Équipements inclus :</h5>
                    <div class="row g-2">
                        <div class="col-md-6"><i class="fas fa-check text-success me-2"></i> GPS Navigation Premium</div>
                        <div class="col-md-6"><i class="fas fa-check text-success me-2"></i> Système Audio Surround</div>
                        <div class="col-md-6"><i class="fas fa-check text-success me-2"></i> Sièges Cuir Chauffants</div>
                        <div class="col-md-6"><i class="fas fa-check text-success me-2"></i> Assistance Parking</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Booking Form (Sticky) -->
        <div class="col-lg-4">
            <div class="card-luxury p-4 shadow-strong sticky-top reveal" style="top: 100px; border-top: 5px solid var(--c-gold);">
                <div class="text-center mb-4">
                    <span class="d-block text-muted small text-uppercase fw-bold mb-1">Tarif Journalier</span>
                    <h2 class="display-4 fw-bold gold mb-0">@Model.PrixJournee.ToString("C0")</h2>
                    <span class="text-muted small">Assurance incluse</span>
                </div>

                <form asp-action="CreerLocation" method="post" class="mt-4">
                    <input type="hidden" name="VehiculeID" value="@Model.VehiculeID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Date de départ</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-calendar-alt gold"></i></span>
                            <input type="date" class="form-control form-control-custom ps-2" 
                                   id="DateDebut" name="DateDebut" required 
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Date de retour</label>
                         <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fas fa-calendar-check gold"></i></span>
                            <input type="date" class="form-control form-control-custom ps-2" 
                                   id="DateFin" name="DateFin" required />
                        </div>
                    </div>

                    <!-- Availability Status -->
                    <div class="text-center mb-4 p-3 rounded" style="background: var(--bg-body);">
                        @if (Model.QuantiteDisponible > 0)
                        {
                            <span class="text-success fw-bold">
                                <i class="fas fa-circle me-2 animate-pulse"></i>Disponible (@Model.QuantiteDisponible en stock)
                            </span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold">
                                <i class="fas fa-times-circle me-2"></i>Actuellement indisponible
                            </span>
                        }
                    </div>

                    @if (Model.QuantiteDisponible > 0)
                    {
                        <button type="submit" class="btn btn-hero w-100 py-3 rounded-pill shadow-gold">
                            <span class="text-uppercase letter-spacing-1">Réserver ce véhicule</span>
                            <i class="fas fa-arrow-right ms-2"></i>
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary w-100 py-3 rounded-pill" disabled>
                            Indisponible
                        </button>
                    }
                </form>

                <div class="mt-4 text-center">
                    <p class="small text-muted mb-0"><i class="fas fa-lock me-1"></i> Paiement 100% sécurisé</p>
                    <p class="small text-muted"><i class="fas fa-bolt me-1"></i> Confirmation immédiate</p>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Back Button Sticky -->
<a asp-controller="Vehicule" asp-action="Index" 
   class="btn btn-dark rounded-circle shadow-lg d-flex align-items-center justify-content-center" 
   style="position: fixed; bottom: 30px; left: 30px; width: 60px; height: 60px; z-index: 1000; border: 2px solid var(--c-gold);">
    <i class="fas fa-arrow-left text-white"></i>
</a>

@section Scripts {
    <script>
        // Use the same reveal observer as Home
        document.addEventListener('DOMContentLoaded', function() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) entry.target.classList.add('active');
                });
            }, { threshold: 0.1 });
            
            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
        });
    </script>
}
