@model LocationVoiture.Core.Models.Vehicule

@{
    ViewData["Title"] = $"{Model.Marque} {Model.Modele}";
}

<!-- FULLSCREEN BACKGROUND -->
<div style="position: fixed; top: 0; left: 0; width: 100%; height: 100vh; z-index: -1;">
    <div style="position: absolute; inset: 0; background: url('@(string.IsNullOrEmpty(Model.ImageURL) ? "/images/hero.png" : Model.ImageURL)') no-repeat center center/cover;"></div>
    <div style="position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10, 26, 47, 0.92) 0%, rgba(10, 26, 47, 0.85) 50%, rgba(10, 26, 47, 0.75) 100%);"></div>
</div>

<div class="container" style="min-height: 100vh; display: flex; align-items: center; padding-top: 120px; padding-bottom: 50px;">
    <div class="row w-100 gy-4 justify-content-center">
        
        <!-- HEADER -->
        <div class="col-12 text-center mb-4">
            <span class="badge mb-3" style="background: var(--c-gold); color: var(--c-night);">
                @Model.TypeVehicule.Nom
            </span>
            <h1 class="display-4 fw-bold text-white">
                @Model.Marque <span class="gold">@Model.Modele</span>
            </h1>
            <p class="lead text-white-50">
                @Model.Annee • @Model.Couleur • @Model.PrixJournee.ToString("C0") / jour
            </p>
        </div>

        <!-- LEFT: IMAGE & SPECS -->
        <div class="col-lg-7">
            <div class="card-luxury p-4 h-100" style="background: rgba(19, 43, 74, 0.8); backdrop-filter: blur(20px); border-color: var(--border-gold);">
                <img src="@(string.IsNullOrEmpty(Model.ImageURL) ? "/images/car1.png" : Model.ImageURL)" 
                     alt="@Model.Modele" 
                     class="img-fluid rounded-3 mb-4 w-100" 
                     style="object-fit: cover; max-height: 400px; box-shadow: var(--shadow-deep);">
                
                <h4 class="mb-4 text-white">
                    <i class="fas fa-cogs gold me-2"></i>Caractéristiques
                </h4>
                <div class="row g-3 text-white-50 text-center">
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background: rgba(201, 164, 76, 0.1); border: 1px solid rgba(201, 164, 76, 0.2);">
                            <i class="fas fa-gas-pump gold mb-2 fa-lg"></i>
                            <div class="small mt-2">Essence</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background: rgba(201, 164, 76, 0.1); border: 1px solid rgba(201, 164, 76, 0.2);">
                            <i class="fas fa-cogs gold mb-2 fa-lg"></i>
                            <div class="small mt-2">Automatique</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background: rgba(201, 164, 76, 0.1); border: 1px solid rgba(201, 164, 76, 0.2);">
                            <i class="fas fa-users gold mb-2 fa-lg"></i>
                            <div class="small mt-2">5 Places</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded" style="background: rgba(201, 164, 76, 0.1); border: 1px solid rgba(201, 164, 76, 0.2);">
                            <i class="fas fa-palette gold mb-2 fa-lg"></i>
                            <div class="small mt-2">@Model.Couleur</div>
                        </div>
                    </div>
                </div>
                
                <hr class="my-4" style="border-color: rgba(255,255,255,0.1);">
                
                <h5 class="text-white mb-3">
                    <i class="fas fa-info-circle gold me-2"></i>Description
                </h5>
                <p class="text-white-50">
                    Découvrez la @Model.Marque @Model.Modele, un véhicule d'exception alliant performance et élégance. 
                    Profitez d'une expérience de conduite unique avec ce modèle @Model.Annee parfaitement entretenu.
                    Équipé des dernières technologies de confort et de sécurité, ce véhicule est prêt pour toutes vos aventures.
                </p>
            </div>
        </div>

        <!-- RIGHT: BOOKING FORM -->
        <div class="col-lg-5">
            <div class="card-luxury p-4 sticky-top" style="top: 100px; background: rgba(19, 43, 74, 0.9); backdrop-filter: blur(20px); border-color: var(--border-gold);">
                <h3 class="text-white mb-4">
                    <i class="fas fa-calendar-check gold me-2"></i>Réserver ce véhicule
                </h3>
                
                <form asp-action="CreerLocation" method="post">
                    <input type="hidden" name="VehiculeID" value="@Model.VehiculeID" />

                    <div class="mb-3">
                        <label class="form-label text-white-50">Date de début</label>
                        <input type="date" class="form-control form-control-custom" 
                               id="DateDebut" name="DateDebut" required 
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50">Date de fin</label>
                        <input type="date" class="form-control form-control-custom" 
                               id="DateFin" name="DateFin" required />
                    </div>

                    <div class="p-3 rounded mb-4" style="background: rgba(201, 164, 76, 0.15); border: 1px solid rgba(201, 164, 76, 0.3);">
                        <div class="d-flex justify-content-between align-items-center text-white">
                            <span>Tarif Journalier</span>
                            <span class="gold fw-bold fs-4">@Model.PrixJournee.ToString("C0")</span>
                        </div>
                    </div>

                    @if (Model.Disponible)
                    {
                        <button type="submit" class="btn btn-hero w-100 py-3">
                            <i class="fas fa-check-circle me-2"></i> Confirmer la réservation
                        </button>
                        <p class="text-white-50 text-center small mt-3 mb-0">
                            <i class="fas fa-shield-alt gold me-1"></i> Paiement sécurisé • Annulation gratuite 24h
                        </p>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary w-100 py-3" disabled 
                                style="background: rgba(100,100,100,0.5); border: none; cursor: not-allowed;">
                            <i class="fas fa-ban me-2"></i> Non disponible
                        </button>
                        <p class="text-white-50 text-center small mt-3 mb-0">
                            Ce véhicule est actuellement réservé. Revenez bientôt!
                        </p>
                    }
                </form>
            </div>
        </div>

    </div>
</div>

<!-- BACK BUTTON -->
<a asp-controller="Vehicule" asp-action="Index" 
   class="btn btn-outline" 
   style="position: fixed; bottom: 30px; left: 30px; z-index: 100; color: white; border-color: rgba(255,255,255,0.3); background: rgba(10,26,47,0.8); backdrop-filter: blur(10px);">
    <i class="fas fa-arrow-left me-2"></i> Retour
</a>
