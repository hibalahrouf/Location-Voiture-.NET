@model LocationVoiture.Core.Models.Client
@{
    ViewData["Title"] = "Mon Tableau de Bord";
}

<div style="min-height: 100vh; padding: 100px 20px 60px; background: linear-gradient(180deg, var(--bg-body) 0%, var(--bg-body) 100%);">
    <div class="container">
        <!-- WELCOME HEADER -->
        <div class="text-center mb-5">
            <div style="width: 120px; height: 120px; background: linear-gradient(135deg, var(--c-night), var(--c-night-light)); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; box-shadow: var(--shadow-deep), 0 0 0 4px var(--c-gold-light); margin-bottom: 1.5rem;">
                <i class="fas fa-user" style="font-size: 3rem; color: white;"></i>
            </div>
            <h1 class="mb-2">Bienvenue, <span class="gold">@Model.Prenom</span>!</h1>
            <p class="text-muted">Gérez votre compte et vos réservations</p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- USER INFO CARD -->
            <div class="col-lg-6">
                <div class="card-luxury h-100">
                    <h4 class="mb-4">
                        <i class="fas fa-id-card gold me-2"></i>Mes Informations
                    </h4>
                    
                    <div class="info-item mb-3 p-3 rounded" style="background: var(--bg-input); border-left: 4px solid var(--c-gold);">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-user gold me-3" style="font-size: 1.2rem;"></i>
                            <div>
                                <small class="text-muted d-block">Nom complet</small>
                                <span class="fw-bold">@Model.Prenom @Model.Nom</span>
                            </div>
                        </div>
                    </div>

                    <div class="info-item mb-3 p-3 rounded" style="background: var(--bg-input); border-left: 4px solid var(--c-gold);">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-envelope gold me-3" style="font-size: 1.2rem;"></i>
                                <div>
                                    <small class="text-muted d-block">Email</small>
                                    <span class="fw-bold">@Model.Email</span>
                                </div>
                            </div>
                            @if (Model.IsEmailVerified)
                            {
                                <span class="badge" style="background: rgba(34, 197, 94, 0.2); color: #22c55e;">
                                    <i class="fas fa-check-circle me-1"></i> Vérifié
                                </span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Telephone))
                    {
                        <div class="info-item mb-3 p-3 rounded" style="background: var(--bg-input); border-left: 4px solid var(--c-gold);">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-phone gold me-3" style="font-size: 1.2rem;"></i>
                                <div>
                                    <small class="text-muted d-block">Téléphone</small>
                                    <span class="fw-bold">@Model.Telephone</span>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Adresse))
                    {
                        <div class="info-item p-3 rounded" style="background: var(--bg-input); border-left: 4px solid var(--c-gold);">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-map-marker-alt gold me-3" style="font-size: 1.2rem;"></i>
                                <div>
                                    <small class="text-muted d-block">Adresse</small>
                                    <span class="fw-bold">@Model.Adresse</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- QUICK ACTIONS CARD -->
            <div class="col-lg-4">
                <div class="card-luxury h-100">
                    <h4 class="mb-4">
                        <i class="fas fa-bolt gold me-2"></i>Actions Rapides
                    </h4>

                    <a asp-controller="Vehicule" asp-action="Index" class="d-block p-3 rounded mb-3 text-decoration-none" 
                       style="background: linear-gradient(135deg, var(--c-gold-light), rgba(201, 164, 76, 0.25)); border: 1px solid var(--border-gold); transition: all var(--trans-smooth);">
                        <div class="d-flex align-items-center">
                            <div style="width: 50px; height: 50px; background: var(--c-gold); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-car" style="color: var(--c-night);"></i>
                            </div>
                            <div class="ms-3">
                                <span class="fw-bold d-block" style="color: var(--c-text-main);">Nos Véhicules</span>
                                <small class="text-muted">Explorez notre collection</small>
                            </div>
                            <i class="fas fa-chevron-right ms-auto gold"></i>
                        </div>
                    </a>

                    <a asp-controller="Home" asp-action="Index" class="d-block p-3 rounded mb-3 text-decoration-none" 
                       style="background: var(--bg-input); border: 1px solid var(--border-color); transition: all var(--trans-smooth);">
                        <div class="d-flex align-items-center">
                            <div style="width: 50px; height: 50px; background: var(--c-night); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-home" style="color: white;"></i>
                            </div>
                            <div class="ms-3">
                                <span class="fw-bold d-block" style="color: var(--c-text-main);">Accueil</span>
                                <small class="text-muted">Retour à la page d'accueil</small>
                            </div>
                            <i class="fas fa-chevron-right ms-auto text-muted"></i>
                        </div>
                    </a>

                    <a asp-controller="Contact" asp-action="Index" class="d-block p-3 rounded mb-4 text-decoration-none" 
                       style="background: var(--bg-input); border: 1px solid var(--border-color); transition: all var(--trans-smooth);">
                        <div class="d-flex align-items-center">
                            <div style="width: 50px; height: 50px; background: var(--c-night); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-headset" style="color: white;"></i>
                            </div>
                            <div class="ms-3">
                                <span class="fw-bold d-block" style="color: var(--c-text-main);">Support</span>
                                <small class="text-muted">Contactez-nous</small>
                            </div>
                            <i class="fas fa-chevron-right ms-auto text-muted"></i>
                        </div>
                    </a>

                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit" class="btn w-100 py-3" 
                                style="background: transparent; border: 2px solid #dc2626; color: #dc2626; border-radius: 50px; font-weight: 600; transition: all var(--trans-smooth);">
                            <i class="fas fa-sign-out-alt me-2"></i> Déconnexion
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
