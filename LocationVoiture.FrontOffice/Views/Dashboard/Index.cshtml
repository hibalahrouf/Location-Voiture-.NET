@model LocationVoiture.Core.Models.Client
@{
    ViewData["Title"] = "Mon Tableau de Bord";
}

<style>
    /* ===== DASHBOARD LUXURY STYLES ===== */
    
    :root {
        --night-blue: #0B1F3F;
        --night-blue-light: #1a3a5c;
        --gold: #B8860B;
        --gold-light: #d4a528;
        --gold-dark: #8b6914;
        --bg-cream: #f8f6f3;
        --bg-card: #ffffff;
        --text-dark: #1a202c;
        --text-muted: #64748b;
        --shadow-blue: rgba(11, 31, 63, 0.12);
        --shadow-gold: rgba(184, 134, 11, 0.15);
    }

    .dashboard-container {
        min-height: 85vh;
        padding: 50px 20px;
        background: linear-gradient(145deg, var(--bg-cream) 0%, #ebe8e3 50%, var(--bg-cream) 100%);
        position: relative;
    }

    .dashboard-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 200px;
        background: linear-gradient(135deg, var(--night-blue) 0%, var(--night-blue-light) 100%);
        opacity: 0.03;
        pointer-events: none;
    }

    .dashboard-card {
        background: var(--bg-card);
        border-radius: 24px;
        box-shadow: 
            0 4px 6px var(--shadow-blue),
            0 10px 40px var(--shadow-blue),
            0 0 0 1px rgba(11, 31, 63, 0.04);
        padding: 50px;
        max-width: 720px;
        margin: 0 auto;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .dashboard-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--gold-dark), var(--gold), var(--gold-light));
    }

    .dashboard-card:hover {
        transform: translateY(-8px);
        box-shadow: 
            0 8px 12px var(--shadow-blue),
            0 25px 60px var(--shadow-blue),
            0 0 0 1px rgba(11, 31, 63, 0.06);
    }

    .dashboard-header {
        text-align: center;
        margin-bottom: 45px;
        padding-bottom: 30px;
        border-bottom: 1px solid rgba(11, 31, 63, 0.08);
        position: relative;
    }

    .dashboard-header::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, var(--gold), var(--gold-light));
        border-radius: 2px;
    }

    .dashboard-header h1 {
        color: var(--night-blue);
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
        letter-spacing: -0.5px;
    }

    .dashboard-header .welcome-text {
        color: var(--gold);
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .user-avatar {
        width: 110px;
        height: 110px;
        background: linear-gradient(145deg, var(--night-blue) 0%, var(--night-blue-light) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 25px;
        box-shadow: 
            0 8px 30px rgba(11, 31, 63, 0.25),
            0 0 0 4px rgba(184, 134, 11, 0.2);
        position: relative;
        transition: all 0.3s ease;
    }

    .user-avatar::after {
        content: '';
        position: absolute;
        inset: -6px;
        border-radius: 50%;
        border: 2px solid var(--gold);
        opacity: 0.3;
    }

    .user-avatar:hover {
        transform: scale(1.05);
        box-shadow: 
            0 12px 40px rgba(11, 31, 63, 0.3),
            0 0 0 6px rgba(184, 134, 11, 0.25);
    }

    .user-avatar i {
        font-size: 3.2rem;
        color: #ffffff;
    }

    .info-section {
        margin-bottom: 35px;
    }

    .info-item {
        display: flex;
        align-items: center;
        padding: 20px 24px;
        background: linear-gradient(135deg, var(--bg-cream) 0%, #f5f3f0 100%);
        border-radius: 16px;
        margin-bottom: 14px;
        border-left: 4px solid var(--gold);
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 2px 8px rgba(11, 31, 63, 0.04);
        position: relative;
        overflow: hidden;
    }

    .info-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(184, 134, 11, 0.05), transparent);
        transition: left 0.5s ease;
    }

    .info-item:hover::before {
        left: 100%;
    }

    .info-item:hover {
        background: linear-gradient(135deg, #f5f3f0 0%, #edeae6 100%);
        transform: translateX(8px);
        box-shadow: 
            0 4px 15px rgba(11, 31, 63, 0.08),
            inset 0 0 0 1px rgba(184, 134, 11, 0.1);
    }

    .info-item i {
        color: var(--night-blue);
        font-size: 1.5rem;
        margin-right: 18px;
        width: 32px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .info-item:hover i {
        color: var(--gold);
        transform: scale(1.1);
    }

    .info-item .info-content {
        flex: 1;
    }

    .info-item .info-label {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
        font-weight: 600;
    }

    .info-item .info-value {
        font-size: 1.1rem;
        color: var(--night-blue);
        font-weight: 600;
    }

    .verified-badge {
        display: inline-flex;
        align-items: center;
        background: linear-gradient(135deg, #059669 0%, #10b981 100%);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        margin-left: 12px;
        box-shadow: 0 4px 12px rgba(5, 150, 105, 0.25);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .verified-badge i {
        color: white !important;
        font-size: 0.85rem;
        margin-right: 6px;
        width: auto;
    }

    .action-section {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid rgba(11, 31, 63, 0.08);
        position: relative;
    }

    .action-section::before {
        content: '';
        position: absolute;
        top: -1px;
        left: 50%;
        transform: translateX(-50%);
        width: 40px;
        height: 3px;
        background: var(--gold);
        border-radius: 2px;
        opacity: 0.5;
    }

    .btn-luxury {
        padding: 16px 32px;
        border-radius: 50px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-size: 0.8rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        position: relative;
        overflow: hidden;
    }

    .btn-luxury::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s ease;
    }

    .btn-luxury:hover::before {
        left: 100%;
    }

    .btn-luxury-primary {
        background: linear-gradient(145deg, var(--night-blue) 0%, var(--night-blue-light) 100%);
        color: white;
        border: none;
        box-shadow: 
            0 6px 20px rgba(11, 31, 63, 0.3),
            inset 0 1px 0 rgba(255,255,255,0.1);
    }

    .btn-luxury-primary:hover {
        background: linear-gradient(145deg, #071428 0%, var(--night-blue) 100%);
        transform: translateY(-4px);
        box-shadow: 
            0 12px 35px rgba(11, 31, 63, 0.4),
            inset 0 1px 0 rgba(255,255,255,0.1);
        color: white;
    }

    .btn-luxury-gold {
        background: linear-gradient(145deg, var(--gold) 0%, var(--gold-light) 100%);
        color: white;
        border: none;
        box-shadow: 
            0 6px 20px var(--shadow-gold),
            inset 0 1px 0 rgba(255,255,255,0.2);
    }

    .btn-luxury-gold:hover {
        background: linear-gradient(145deg, var(--gold-dark) 0%, var(--gold) 100%);
        transform: translateY(-4px);
        box-shadow: 
            0 12px 35px rgba(184, 134, 11, 0.4),
            inset 0 1px 0 rgba(255,255,255,0.2);
        color: white;
    }

    .btn-logout {
        background: transparent;
        color: #dc2626;
        border: 2px solid #dc2626;
        box-shadow: none;
    }

    .btn-logout:hover {
        background: linear-gradient(145deg, #dc2626 0%, #ef4444 100%);
        color: white;
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(220, 38, 38, 0.3);
        border-color: transparent;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .dashboard-card {
            padding: 30px 20px;
            margin: 0 15px;
        }
        
        .dashboard-header h1 {
            font-size: 1.75rem;
        }
        
        .action-section {
            flex-direction: column;
            align-items: stretch;
        }
        
        .btn-luxury {
            justify-content: center;
        }
    }
</style>

<div class="dashboard-container">
    <div class="dashboard-card">
        <div class="dashboard-header">
            <div class="user-avatar">
                <i class="bi bi-person-fill"></i>
            </div>
            <h1>Bienvenue, @Model.Prenom!</h1>
            <span class="welcome-text">Votre espace personnel</span>
        </div>

        <div class="info-section">
            <div class="info-item">
                <i class="bi bi-person"></i>
                <div class="info-content">
                    <div class="info-label">Nom complet</div>
                    <div class="info-value">@Model.Prenom @Model.Nom</div>
                </div>
            </div>

            <div class="info-item">
                <i class="bi bi-envelope"></i>
                <div class="info-content">
                    <div class="info-label">Email</div>
                    <div class="info-value">
                        @Model.Email
                        @if (Model.IsEmailVerified)
                        {
                            <span class="verified-badge">
                                <i class="bi bi-check-circle-fill"></i>
                                Verifie
                            </span>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Telephone))
            {
                <div class="info-item">
                    <i class="bi bi-telephone"></i>
                    <div class="info-content">
                        <div class="info-label">Telephone</div>
                        <div class="info-value">@Model.Telephone</div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Adresse))
            {
                <div class="info-item">
                    <i class="bi bi-geo-alt"></i>
                    <div class="info-content">
                        <div class="info-label">Adresse</div>
                        <div class="info-value">@Model.Adresse</div>
                    </div>
                </div>
            }
        </div>

        <div class="action-section">
            <a asp-controller="Home" asp-action="Index" class="btn-luxury btn-luxury-primary">
                <i class="bi bi-house"></i>
                Accueil
            </a>
            <a asp-controller="Vehicule" asp-action="Index" class="btn-luxury btn-luxury-gold">
                <i class="bi bi-car-front"></i>
                Vehicules
            </a>
            <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="display: inline;">
                <button type="submit" class="btn-luxury btn-logout">
                    <i class="bi bi-box-arrow-right"></i>
                    Deconnexion
                </button>
            </form>
        </div>
    </div>
</div>
