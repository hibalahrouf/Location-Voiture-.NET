<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Premium Auto</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <!-- NAVIGATION -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light nav-luxury fixed-top">
            <div class="container">
                <a class="navbar-brand brand-title" asp-controller="Home" asp-action="Index">
                    Location<span class="gold">Voiture</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- Centered Links -->
                    <ul class="navbar-nav mx-auto align-items-center gap-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Vehicule" asp-action="Index">Nos Véhicules</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">Contact</a>
                        </li>
                    </ul>

                    <!-- Right Side Items -->
                    <div class="d-flex align-items-center gap-3">
                        <partial name="_LoginPartial" />
                        <button class="theme-toggle" id="themeToggle" title="Toggle Light/Dark Mode" style="margin-right: 0;">
                            <i class="fas fa-sun"></i>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENT (No container wrapper by default to allow full width hero) -->
    <main role="main" class="pb-3">
        @if (TempData["Error"] != null)
        {
            <div class="container mt-5 pt-5">
                <div class="alert alert-danger">@TempData["Error"]</div>
            </div>
        }
        @if (TempData["Success"] != null)
        {
           <div class="container mt-5 pt-5">
               <div class="alert alert-success">@TempData["Success"]</div>
           </div>
        }

        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer-luxury">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h3 class="brand-title mb-4">Location<span class="gold">Voiture</span></h3>
                    <p class="text-muted">
                        Votre partenaire de confiance pour la location de véhicules de luxe. 
                        Une expérience inoubliable à chaque trajet.
                    </p>
                    <div class="mt-4">
                        <a href="#" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h5 class="text-light mb-4">Liens Rapides</h5>
                    <a href="#" class="footer-link">Accueil</a>
                    <a href="#" class="footer-link">Nos Véhicules</a>
                    <a href="#" class="footer-link">À Propos</a>
                    <a href="#" class="footer-link">Contact</a>
                </div>
                <div class="col-md-3 mb-4">
                    <h5 class="text-light mb-4">Contact</h5>
                    <p class="text-muted"><i class="fas fa-map-marker-alt me-2 gold"></i> 123 Avenue des Champs, Paris</p>
                    <p class="text-muted"><i class="fas fa-phone me-2 gold"></i> +33 1 23 45 67 89</p>
                    <p class="text-muted"><i class="fas fa-envelope me-2 gold"></i> contact@premiumauto.com</p>
                </div>
                <div class="col-md-3 mb-4">
                    <h5 class="text-light mb-4">Newsletter</h5>
                    <p class="text-muted">Inscrivez-vous pour recevoir nos offres exclusives.</p>
                    <div class="input-group">
                        <input type="email" class="form-control form-control-custom" placeholder="Votre email">
                        <button class="btn btn-login" type="button"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </div>
            </div>
            <hr class="border-secondary my-4">
            <div class="text-center text-muted">
                <p>&copy; 2025 LocationVoiture Premium. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Theme Toggle Logic -->
    <!-- Theme Toggle Logic Removed: Forced Dark Mode -->
    <!-- Theme Toggle Logic -->
    <script>
        const themeToggle = document.getElementById('themeToggle');
        const icon = themeToggle.querySelector('i');
        const html = document.documentElement;

        // Check saved preference
        const savedTheme = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-theme', savedTheme);
        updateIcon(savedTheme);

        // Toggle Event
        themeToggle.addEventListener('click', () => {
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateIcon(newTheme);
        });

        function updateIcon(theme) {
            if (theme === 'dark') {
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            } else {
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
