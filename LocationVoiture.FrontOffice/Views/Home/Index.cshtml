@model IEnumerable<LocationVoiture.Core.Models.Vehicule>

@{
    ViewData["Title"] = "Accueil";
}

<!-- HERO SECTION -->
<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="hero-content fade-in-up">
                    <span class="badge mb-3" style="background: var(--c-gold); color: var(--c-night);">
                        <i class="fas fa-star me-1"></i> Service Premium
                    </span>
                    <h1 class="hero-title">L'Excellence<br>Automobile</h1>
                    <p class="hero-subtitle">
                        Découvrez notre collection exclusive de véhicules de luxe. 
                        Une expérience de conduite incomparable vous attend.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a asp-controller="Vehicule" asp-action="Index" class="btn btn-hero">
                            Explorer <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                        <a asp-controller="Contact" asp-action="Index" class="btn btn-outline-gold">
                            Nous contacter
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-5 offset-lg-1">
                <div class="search-card fade-in-up" style="animation-delay: 0.2s;">
                    <h3 class="mb-4 text-white fw-bold">
                        <i class="fas fa-search me-2 gold"></i>Trouvez votre véhicule
                    </h3>
                    <form asp-controller="Vehicule" asp-action="Index" method="get">
                        <div class="mb-3">
                            <label class="form-label">Lieu de prise en charge</label>
                            <div class="input-group">
                                <span class="input-group-text" style="background: rgba(255,255,255,0.1); border: none;">
                                    <i class="fas fa-map-marker-alt gold"></i>
                                </span>
                                <input type="text" class="form-control form-control-custom" placeholder="Paris, Aéroport CDG...">
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Date de départ</label>
                                <input type="date" class="form-control form-control-custom">
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Date de retour</label>
                                <input type="date" class="form-control form-control-custom">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Type de véhicule</label>
                            <select class="form-select form-control-custom">
                                <option selected>Tous les véhicules</option>
                                <option>Sportive</option>
                                <option>SUV de Luxe</option>
                                <option>Cabriolet</option>
                                <option>Berline</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-hero w-100">
                            <i class="fas fa-search me-2"></i> Rechercher
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEATURED CARS SECTION -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge mb-2">Collection</span>
            <h2 class="section-title">Véhicules en Vedette</h2>
            <p class="text-muted">Découvrez notre sélection premium de véhicules d'exception</p>
        </div>

        <div class="row g-4">
            @if (Model.Any())
            {
                @foreach (var car in Model.Take(6))
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="car-card fade-in-up">
                            <div class="car-img-wrapper">
                                <img src="@(string.IsNullOrEmpty(car.ImageURL) ? "/images/car1.png" : car.ImageURL)" alt="@car.Modele">
                                <span class="position-absolute top-0 end-0 m-3 badge" 
                                      style="background: rgba(10,26,47,0.9); color: var(--c-gold); border: 1px solid var(--c-gold);">
                                    @car.TypeVehicule?.Nom
                                </span>
                            </div>
                            <div class="car-details">
                                <h5 class="car-title">@car.Marque @car.Modele</h5>
                                <div class="d-flex justify-content-between text-muted small mb-3">
                                    <span><i class="fas fa-calendar-alt gold me-1"></i> @car.Annee</span>
                                    <span><i class="fas fa-cog gold me-1"></i> Auto</span>
                                    <span><i class="fas fa-palette gold me-1"></i> @car.Couleur</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center pt-3 border-top" style="border-color: var(--border-color) !important;">
                                    <span class="car-price">
                                        @car.PrixJournee.ToString("C0")
                                        <small>/jour</small>
                                    </span>
                                    <a asp-controller="Vehicule" asp-action="Details" asp-route-id="@car.VehiculeID" 
                                       class="btn btn-sm btn-outline-gold">
                                        Détails <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="icon-circle mx-auto mb-4">
                        <i class="fas fa-car"></i>
                    </div>
                    <h4 class="text-muted">Aucun véhicule disponible pour le moment</h4>
                    <p class="text-muted">Revenez bientôt pour découvrir notre collection.</p>
                </div>
            }
        </div>
        
        <div class="text-center mt-5">
            <a asp-controller="Vehicule" asp-action="Index" class="btn btn-outline-gold px-5">
                <i class="fas fa-th me-2"></i> Voir toute la collection
            </a>
        </div>
    </div>
</section>

<!-- ADVANTAGES SECTION -->
<section class="py-5 bg-night-lighter">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge mb-2">Pourquoi nous choisir</span>
            <h2 class="section-title">Nos Avantages</h2>
        </div>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="icon-circle">
                        <i class="fas fa-car"></i>
                    </div>
                    <h4 class="feature-title">Véhicules Premium</h4>
                    <p class="feature-text">
                        Une flotte exclusivement composée de véhicules haut de gamme, 
                        entretenus avec le plus grand soin.
                    </p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="icon-circle">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h4 class="feature-title">Support 24/7</h4>
                    <p class="feature-text">
                        Une équipe dédiée disponible à tout moment pour répondre 
                        à vos questions et vous accompagner.
                    </p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="feature-card h-100">
                    <div class="icon-circle">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4 class="feature-title">Assurance Complète</h4>
                    <p class="feature-text">
                        Roulez l'esprit tranquille avec notre couverture 
                        d'assurance tous risques incluse.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS SECTION -->
<section class="py-5" style="background: var(--c-night);">
    <div class="container">
        <div class="row text-center text-white">
            <div class="col-6 col-md-3 mb-4 mb-md-0">
                <div class="display-4 gold fw-bold">150+</div>
                <p class="text-white-50 mb-0">Véhicules</p>
            </div>
            <div class="col-6 col-md-3 mb-4 mb-md-0">
                <div class="display-4 gold fw-bold">50K+</div>
                <p class="text-white-50 mb-0">Clients Satisfaits</p>
            </div>
            <div class="col-6 col-md-3">
                <div class="display-4 gold fw-bold">15+</div>
                <p class="text-white-50 mb-0">Années d'expérience</p>
            </div>
            <div class="col-6 col-md-3">
                <div class="display-4 gold fw-bold">4.9</div>
                <p class="text-white-50 mb-0">Note moyenne</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="py-5">
    <div class="container">
        <div class="card-luxury text-center p-5" style="background: linear-gradient(135deg, var(--c-night) 0%, var(--c-night-light) 100%); border-color: var(--border-gold);">
            <h2 class="text-white mb-3">Prêt pour l'aventure ?</h2>
            <p class="text-white-50 mb-4">Réservez votre véhicule de rêve dès maintenant et vivez une expérience inoubliable.</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Vehicule" asp-action="Index" class="btn btn-hero">
                    Réserver maintenant
                </a>
                <a href="tel:+33123456789" class="btn btn-outline" style="color: white; border-color: rgba(255,255,255,0.3);">
                    <i class="fas fa-phone me-2"></i> +33 1 23 45 67 89
                </a>
            </div>
        </div>
    </div>
</section>
