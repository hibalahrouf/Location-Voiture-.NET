@model IEnumerable<LocationVoiture.Core.Models.Vehicule>

@{
    ViewData["Title"] = "Accueil";
}

<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="hero-content">
                    <h1 class="hero-title">Location de <br>Voitures de Luxe</h1>
                    <p class="hero-subtitle">Réservez la voiture de vos rêves facilement et rapidement. Vivez l'expérience du luxe absolu.</p>
                    <a asp-controller="Vehicule" asp-action="Index" class="btn btn-hero">
                        Voir les Véhicules <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
            
            <div class="col-lg-5 offset-lg-1">
                <div class="search-card">
                    <div class="search-card-content">
                        <h3 class="mb-4 text-white">Trouver votre voiture</h3>
                        <form asp-controller="Vehicule" asp-action="Index" method="get">
                            <div class="mb-3">
                                <label class="form-label">Lieu de prise en charge</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-transparent border-end-0 text-muted" style="border-color: rgba(255,255,255,0.1)"><i class="fas fa-map-marker-alt"></i></span>
                                    <input type="text" class="form-control form-control-custom border-start-0" placeholder="Ville, Aéroport...">
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Date de départ</label>
                                    <input type="date" class="form-control form-control-custom">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Date de retour</label>
                                    <input type="date" class="form-control form-control-custom">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Type de véhicule</label>
                                <select class="form-select form-control-custom">
                                    <option selected>Tous les véhicules</option>
                                    <option>Sportive</option>
                                    <option>SUV de Luxe</option>
                                    <option>Cabriolet</option>
                                    <option>Berline</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-search">
                                Rechercher
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Featured Cars Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Véhicules en Vedette</h2>
            <p class="text-muted">Choisissez parmi notre collection exclusive de véhicules premium</p>
        </div>

        <div id="featuredCarsCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                
                @if (Model.Any())
                {
                    <div class="carousel-item active">
                        <div class="row">
                            @foreach (var car in Model)
                            {
                                <div class="col-md-4">
                                    <div class="car-card">
                                        <div class="car-img-wrapper">
                                            <img src="@(string.IsNullOrEmpty(car.ImageURL) ? "/images/car1.png" : car.ImageURL)" alt="@car.Modele">
                                        </div>
                                        <div class="car-details">
                                            <h5 class="car-title">@car.Marque @car.Modele</h5>
                                            <div class="car-specs d-flex justify-content-between mb-3 text-muted small">
                                                <span><i class="fas fa-calendar-alt gold"></i> @car.Annee</span>
                                                <span><i class="fas fa-cog gold"></i> Auto</span>
                                                <span><i class="fas fa-palette gold"></i> @car.Couleur</span>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center mt-3 border-top border-white-10 pt-3">
                                                <span class="car-price">@car.PrixJournee.ToString("C0")<small class="text-muted fw-normal fs-6">/jour</small></span>
                                                <a asp-controller="Vehicule" asp-action="Details" asp-route-id="@car.VehiculeID" class="btn btn-sm btn-outline-light rounded-pill px-4">Détails</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center">
                        <p class="text-muted">Aucun véhicule disponible pour le moment.</p>
                    </div>
                }

            </div>
        </div>
        
        <div class="text-center mt-5">
            <a asp-controller="Vehicule" asp-action="Index" class="btn btn-outline-gold px-5 rounded-pill">Voir toute la flotte</a>
        </div>
    </div>
</section>

<!-- Advantages Section -->
<section class="py-5 bg-night-lighter">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Nos Avantages</h2>
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="feature-card text-center h-100 p-4">
                    <div class="icon-circle mx-auto mb-4">
                        <i class="fas fa-car fa-2x"></i>
                    </div>
                    <h4 class="feature-title mb-3">Véhicules Premium</h4>
                    <p class="feature-text text-muted">Nous sélectionnons rigoureusement les meilleures voitures pour une expérience de conduite ultime.</p>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="feature-card text-center h-100 p-4">
                    <div class="icon-circle mx-auto mb-4">
                        <i class="fas fa-headset fa-2x"></i>
                    </div>
                    <h4 class="feature-title mb-3">Service 24/7</h4>
                    <p class="feature-text text-muted">Notre équipe de support est toujours prête à vous aider pour toute question ou assistance routière.</p>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="feature-card text-center h-100 p-4">
                    <div class="icon-circle mx-auto mb-4">
                        <i class="fas fa-mobile-alt fa-2x"></i>
                    </div>
                    <h4 class="feature-title mb-3">Réservation Facile</h4>
                    <p class="feature-text text-muted">Réservez votre voiture en quelques clics via notre site web moderne et sécurisé.</p>
                </div>
            </div>
        </div>
    </div>
</section>
