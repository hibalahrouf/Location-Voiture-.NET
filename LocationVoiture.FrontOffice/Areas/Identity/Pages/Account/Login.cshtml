@page
@model LocationVoiture.FrontOffice.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Connexion";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Premium Auto</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body data-theme="dark">

<div class="auth-page">
    <!-- Left: Brand Section -->
    <div class="auth-brand-section">
        <div class="auth-brand-content">
            <a href="/" class="text-decoration-none">
                <h1 class="mb-3">Location<span class="gold">Voiture</span></h1>
            </a>
            <p class="mb-5">Accédez à la collection la plus exclusive de véhicules de luxe.</p>
            
            <div class="d-flex justify-content-center gap-4 mt-4">
                <div class="text-center">
                    <div class="display-4 gold fw-bold">150+</div>
                    <small class="text-white-50">Véhicules</small>
                </div>
                <div class="text-center">
                    <div class="display-4 gold fw-bold">50K+</div>
                    <small class="text-white-50">Clients</small>
                </div>
                <div class="text-center">
                    <div class="display-4 gold fw-bold">4.9</div>
                    <small class="text-white-50">Note</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Form Section -->
    <div class="auth-form-section">
        <div class="auth-form-container">
            <!-- Back to Home -->
            <a href="/" class="d-inline-flex align-items-center text-muted mb-4 hover-gold">
                <i class="fas fa-arrow-left me-2"></i> Retour à l'accueil
            </a>

            <div class="auth-form-card">
                <div class="auth-form-header">
                    <div class="icon-circle mb-3">
                        <i class="fas fa-user"></i>
                    </div>
                    <h2>Bienvenue</h2>
                    <p>Connectez-vous à votre espace privilège</p>
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope gold"></i></span>
                            <input asp-for="Input.Email" class="form-control form-control-custom" 
                                   autocomplete="username" aria-required="true" placeholder="votre@email.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label">Mot de passe</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock gold"></i></span>
                            <input asp-for="Input.Password" class="form-control form-control-custom" 
                                   autocomplete="current-password" aria-required="true" placeholder="••••••••" type="password" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label text-muted small" asp-for="Input.RememberMe">
                                Se souvenir de moi
                            </label>
                        </div>
                        <a asp-page="./ForgotPassword" class="text-muted small hover-gold">Mot de passe oublié ?</a>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-hero w-100 py-3 mb-3">
                        SE CONNECTER <i class="fas fa-arrow-right ms-2"></i>
                    </button>

                    <div class="text-center mt-4">
                        <span class="text-muted">Pas encore de compte ? </span>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="gold fw-bold">Créer un compte</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
