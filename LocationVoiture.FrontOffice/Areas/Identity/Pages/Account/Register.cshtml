@page
@model LocationVoiture.FrontOffice.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Inscription";
}

<div class="auth-root">
    <div class="auth-overlay"></div>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header text-center mb-4">
                <div class="icon-circle mb-3 mx-auto" style="width: 80px; height: 80px; background: rgba(251, 191, 36, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 20px rgba(251, 191, 36, 0.2);">
                    <i class="fas fa-user-plus fa-3x gold"></i>
                </div>
                <h2 class="fw-bold text-white">Créer un Compte</h2>
                <p class="text-muted mb-0">Rejoignez le club Premium dès aujourd'hui</p>
            </div>
            <div class="auth-body">
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--input-border);"><i class="fas fa-user gold"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input asp-for="Input.Prenom" class="form-control form-control-custom border-start-0" autocomplete="given-name" placeholder="Prénom" />
                                    <label asp-for="Input.Prenom" class="form-label">Prénom</label>
                                </div>
                            </div>
                            <span asp-validation-for="Input.Prenom" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--input-border);"><i class="fas fa-user gold"></i></span>
                                <div class="form-floating flex-grow-1">
                                    <input asp-for="Input.Nom" class="form-control form-control-custom border-start-0" autocomplete="family-name" placeholder="Nom" />
                                    <label asp-for="Input.Nom" class="form-label">Nom</label>
                                </div>
                            </div>
                            <span asp-validation-for="Input.Nom" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="input-group mb-3">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--input-border);"><i class="fas fa-phone gold"></i></span>
                        <div class="form-floating flex-grow-1">
                            <input asp-for="Input.Telephone" class="form-control form-control-custom border-start-0" autocomplete="tel" placeholder="Téléphone" />
                            <label asp-for="Input.Telephone" class="form-label">Téléphone</label>
                        </div>
                        <span asp-validation-for="Input.Telephone" class="text-danger"></span>
                    </div>

                    <div class="input-group mb-3">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--input-border);"><i class="fas fa-map-marker-alt gold"></i></span>
                        <div class="form-floating flex-grow-1">
                            <input asp-for="Input.Adresse" class="form-control form-control-custom border-start-0" autocomplete="street-address" placeholder="Adresse" />
                            <label asp-for="Input.Adresse" class="form-label">Adresse</label>
                        </div>
                        <span asp-validation-for="Input.Adresse" class="text-danger"></span>
                    </div>

                    <div class="input-group mb-3">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--input-border);"><i class="fas fa-envelope gold"></i></span>
                        <div class="form-floating flex-grow-1">
                            <input asp-for="Input.Email" class="form-control form-control-custom border-start-0" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="form-label">Email</label>
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="input-group mb-3">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--input-border);"><i class="fas fa-lock gold"></i></span>
                        <div class="form-floating flex-grow-1">
                            <input asp-for="Input.Password" class="form-control form-control-custom border-start-0" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="form-label">Mot de passe</label>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="input-group mb-4">
                        <span class="input-group-text bg-transparent border-end-0" style="border-color: var(--input-border);"><i class="fas fa-lock gold"></i></span>
                        <div class="form-floating flex-grow-1">
                            <input asp-for="Input.ConfirmPassword" class="form-control form-control-custom border-start-0" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.ConfirmPassword" class="form-label">Confirmer</label>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-hero w-100 py-3 mb-3 fw-bold" style="font-size: 1.1rem; letter-spacing: 1px;">
                        S'INSCRIRE <i class="fas fa-user-plus ms-2"></i>
                    </button>

                    <div class="text-center mt-4">
                        <span class="text-muted">Vous avez déjà un compte ? </span>
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="gold fw-bold text-decoration-none">Connectez-vous</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}