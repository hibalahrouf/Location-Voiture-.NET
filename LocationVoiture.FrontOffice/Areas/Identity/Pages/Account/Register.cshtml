@page
@model LocationVoiture.FrontOffice.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Inscription";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Premium Auto</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body data-theme="dark">

<div class="auth-page">
    <!-- Left: Brand Section -->
    <div class="auth-brand-section">
        <div class="auth-brand-content">
            <a href="/" class="text-decoration-none">
                <h1 class="mb-3">Location<span class="gold">Voiture</span></h1>
            </a>
            <p class="mb-5">Rejoignez le club des conducteurs d'exception et accédez à des véhicules prestigieux.</p>
            
            <div class="mt-5">
                <div class="d-flex align-items-center justify-content-center gap-3 mb-4">
                    <div class="icon-circle" style="width: 50px; height: 50px; font-size: 1rem;">
                        <i class="fas fa-check"></i>
                    </div>
                    <span class="text-white-50">Réservation instantanée</span>
                </div>
                <div class="d-flex align-items-center justify-content-center gap-3 mb-4">
                    <div class="icon-circle" style="width: 50px; height: 50px; font-size: 1rem;">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <span class="text-white-50">Assurance incluse</span>
                </div>
                <div class="d-flex align-items-center justify-content-center gap-3">
                    <div class="icon-circle" style="width: 50px; height: 50px; font-size: 1rem;">
                        <i class="fas fa-headset"></i>
                    </div>
                    <span class="text-white-50">Support 24/7</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Form Section -->
    <div class="auth-form-section" style="overflow-y: auto;">
        <div class="auth-form-container" style="max-width: 500px;">
            <!-- Back to Home -->
            <a href="/" class="d-inline-flex align-items-center text-muted mb-4 hover-gold">
                <i class="fas fa-arrow-left me-2"></i> Retour à l'accueil
            </a>

            <div class="auth-form-card">
                <div class="auth-form-header">
                    <div class="icon-circle mb-3">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <h2>Créer un Compte</h2>
                    <p>Rejoignez le club Premium</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>
                    
                    <!-- Name Row -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.Prenom" class="form-label">Prénom</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user gold"></i></span>
                                <input asp-for="Input.Prenom" class="form-control form-control-custom" 
                                       autocomplete="given-name" placeholder="Jean" />
                            </div>
                            <span asp-validation-for="Input.Prenom" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Input.Nom" class="form-label">Nom</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user gold"></i></span>
                                <input asp-for="Input.Nom" class="form-control form-control-custom" 
                                       autocomplete="family-name" placeholder="Dupont" />
                            </div>
                            <span asp-validation-for="Input.Nom" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Phone -->
                    <div class="mb-3">
                        <label asp-for="Input.Telephone" class="form-label">Téléphone</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-phone gold"></i></span>
                            <input asp-for="Input.Telephone" class="form-control form-control-custom" 
                                   autocomplete="tel" placeholder="+33 6 12 34 56 78" />
                        </div>
                        <span asp-validation-for="Input.Telephone" class="text-danger small"></span>
                    </div>

                    <!-- Address -->
                    <div class="mb-3">
                        <label asp-for="Input.Adresse" class="form-label">Adresse</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-map-marker-alt gold"></i></span>
                            <input asp-for="Input.Adresse" class="form-control form-control-custom" 
                                   autocomplete="street-address" placeholder="123 Rue Example, Paris" />
                        </div>
                        <span asp-validation-for="Input.Adresse" class="text-danger small"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope gold"></i></span>
                            <input asp-for="Input.Email" class="form-control form-control-custom" 
                                   autocomplete="email" aria-required="true" placeholder="votre@email.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Mot de passe</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock gold"></i></span>
                            <input asp-for="Input.Password" class="form-control form-control-custom" 
                                   autocomplete="new-password" aria-required="true" placeholder="••••••••" type="password" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Confirmer le mot de passe</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock gold"></i></span>
                            <input asp-for="Input.ConfirmPassword" class="form-control form-control-custom" 
                                   autocomplete="new-password" aria-required="true" placeholder="••••••••" type="password" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn btn-hero w-100 py-3 mb-3">
                        S'INSCRIRE <i class="fas fa-user-plus ms-2"></i>
                    </button>

                    <div class="text-center mt-4">
                        <span class="text-muted">Vous avez déjà un compte ? </span>
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="gold fw-bold">Connectez-vous</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>