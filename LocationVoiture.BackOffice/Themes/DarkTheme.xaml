<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- ===== DARK THEME COLORS ===== -->
    <SolidColorBrush x:Key="ThemeBackground" Color="#121212"/>
    <SolidColorBrush x:Key="ThemeSecondary" Color="#1E1E2F"/>
    <SolidColorBrush x:Key="ThemeHeader" Color="#0B1F3F"/>
    <SolidColorBrush x:Key="ThemeHeaderLight" Color="#1a3a5c"/>
    <SolidColorBrush x:Key="ThemeGold" Color="#B8860B"/>
    <SolidColorBrush x:Key="ThemeGoldLight" Color="#d4a528"/>
    <SolidColorBrush x:Key="ThemeText" Color="#f0f0f0"/>
    <SolidColorBrush x:Key="ThemeTextSecondary" Color="#a0a0a0"/>
    <SolidColorBrush x:Key="ThemeTextInverse" Color="#ffffff"/>
    <SolidColorBrush x:Key="ThemeBorder" Color="#333333"/>
    <SolidColorBrush x:Key="ThemeRowAlt" Color="#252538"/>
    <SolidColorBrush x:Key="ThemeRowHover" Color="#3d3d50"/>
    <SolidColorBrush x:Key="ThemeMenuBar" Color="#1E1E2F"/>
    
</ResourceDictionary>
