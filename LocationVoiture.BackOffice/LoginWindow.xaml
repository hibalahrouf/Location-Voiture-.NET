<Window x:Class="LocationVoiture.BackOffice.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Connexion - BackOffice" Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgDark" Color="#0f172a"/>
        <SolidColorBrush x:Key="BgDarker" Color="#020617"/>
        <SolidColorBrush x:Key="Gold" Color="#fbbf24"/>
        <SolidColorBrush x:Key="TextWhite" Color="#f8fafc"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94a3b8"/>
        <SolidColorBrush x:Key="InputBg" Color="#1e293b"/>
        
        <!-- Styles -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnHero" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Gold}"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f59e0b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

         <Style x:Key="BtnClose" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="✕" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Gold}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgDarker}" CornerRadius="20" BorderBrush="#334155" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="10" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Close Button -->
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Form -->
                <RowDefinition Height="*"/>    <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Close Button -->
            <Button Style="{StaticResource BtnClose}" HorizontalAlignment="Right" Click="BtnClose_Click"/>

            <!-- Header -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,20,0,40">
                <!-- Icon Placeholder -->
                <Border Width="80" Height="80" CornerRadius="40" Background="#1e293b" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="{StaticResource Gold}" BlurRadius="20" Opacity="0.2"/>
                    </Border.Effect>
                    <TextBlock Text="🔒" FontSize="40" Foreground="{StaticResource Gold}" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/>
                </Border>
                
                <TextBlock Text="Connexion Admin" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextWhite}" HorizontalAlignment="Center"/>
                <TextBlock Text="Espace de Gestion" FontSize="14" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Email" Foreground="{StaticResource TextMuted}" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Height="45" Margin="0,0,0,20"/>

                <TextBlock Text="Mot de passe" Foreground="{StaticResource TextMuted}" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="45" Margin="0,0,0,30"/>

                <Button Content="SE CONNECTER" Style="{StaticResource BtnHero}" Height="50" Click="BtnLogin_Click"/>
            </StackPanel>

            <!-- Footer -->
            <StackPanel Grid.Row="3" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                <TextBlock Text="LocationVoiture © 2025" Foreground="{StaticResource TextMuted}" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
