                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: EMPLOYES -->
            <TabItem Header="Gestion des Employés">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="400"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,15,0" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource NightBlue}" CornerRadius="12,12,0,0" Padding="15,0">
                                <TextBlock Text="👔 Équipe" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Border>
                            <DataGrid x:Name="EmployesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="EmployesGrid_SelectionChanged" MinHeight="300" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding EmployeID}" Width="50"/>
                                    <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*"/>
                                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*"/>
                                    <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource GoldColor}" CornerRadius="12,12,0,0" Padding="15,0">
                                <TextBlock Text="✏️ Formulaire Employé" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Prénom:" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtPrenomEmploye" Margin="0,5,0,10"/>
                                    <TextBlock Text="Nom:" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtNomEmploye" Margin="0,5,0,10"/>
                                    <TextBlock Text="Email:" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtEmailEmploye" Margin="0,5,0,10"/>
                                    <TextBlock Text="Rôle:" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtRoleEmploye" Margin="0,5,0,10"/>
                                    <TextBlock Text="Mot de Passe:" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtMotDePasseEmploye" Margin="0,5,0,15"/>
                                    
                                    <Button Content="➕ Ajouter" Margin="0,5" Click="btnAjouterEmploye_Click"/>
                                    <Button Content="✏️ Modifier" Margin="0,5" Click="btnMettreAJourEmploye_Click" Background="{StaticResource NightBlue}"/>
                                    <Button Content="🗑️ Supprimer" Margin="0,5" Click="btnSupprimerEmploye_Click" Background="#dc2626"/>
                                    <Button Content="🔄 Effacer" Margin="0,5" Click="btnEffacerEmploye_Click" Background="#6b7280"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: ENTRETIENS -->
            <TabItem Header="Gestion des Entretiens">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="400"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,15,0" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource NightBlue}" CornerRadius="12,12,0,0" Padding="15,0">
                                <TextBlock Text="🔧 Historique Entretiens" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Border>
                            <DataGrid x:Name="EntretiensGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="EntretiensGrid_SelectionChanged" MinHeight="300" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding EntretienID}" Width="50"/>
                                    <DataGridTextColumn Header="Véhicule" Binding="{Binding Vehicule.Immatriculation}" Width="*"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateEntretien, StringFormat='d'}" Width="80"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                                    <DataGridTextColumn Header="Coût" Binding="{Binding Cout, StringFormat=C}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource GoldColor}" CornerRadius="12,12,0,0" Padding="15,0">
                                <TextBlock Text="✏️ Formulaire Entretien" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="Véhicule:" FontWeight="SemiBold"/>
                                    <ComboBox x:Name="cmbEntretienVehicule" Margin="0,5,0,10" DisplayMemberPath="Immatriculation" SelectedValuePath="VehiculeID"/>
                                    <TextBlock Text="Date entretien:" FontWeight="SemiBold"/>
                                    <DatePicker x:Name="dpEntretienDate" Margin="0,5,0,10"/>
                                    <TextBlock Text="Description:" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtEntretienDescription" Margin="0,5,0,10" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    <TextBlock Text="Coût (€):" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtEntretienCout" Margin="0,5,0,15"/>
                                    
                                    <Button Content="➕ Ajouter" Margin="0,5" Click="btnAjouterEntretien_Click"/>
                                    <Button Content="✏️ Modifier" Margin="0,5" Click="btnMettreAJourEntretien_Click" Background="{StaticResource NightBlue}"/>
                                    <Button Content="🗑️ Supprimer" Margin="0,5" Click="btnSupprimerEntretien_Click" Background="#dc2626"/>
                                    <Button Content="🔄 Effacer" Margin="0,5" Click="btnEffacerEntretien_Click" Background="#6b7280"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: PAIEMENTS -->
            <TabItem Header="Gestion des Paiements">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Locations Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource NightBlue}" CornerRadius="12,12,0,0" Padding="15,0">
                                <TextBlock Text="📋 Locations à payer" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Border>
                            <DataGrid x:Name="LocationsPaiementGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="LocationsPaiementGrid_SelectionChanged" MinHeight="250" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding LocationID}" Width="50"/>
                                    <DataGridTextColumn Header="Client" Binding="{Binding Client.NomComplet}" Width="*"/>
                                    <DataGridTextColumn Header="Véhicule" Binding="{Binding Vehicule.Immatriculation}" Width="*"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding MontantTotal, StringFormat=C}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                    
                    <!-- Right: Payments & Form -->
                    <Grid Grid.Column="1" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="White" CornerRadius="12" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource NightBlue}" CornerRadius="12,12,0,0" Padding="15,0">
                                    <TextBlock Text="💳 Historique Paiements" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Border>
                                <DataGrid x:Name="PaiementsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="150" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DatePaiement, StringFormat='g'}" Width="*"/>
                                        <DataGridTextColumn Header="Montant" Binding="{Binding Montant, StringFormat=C}" Width="*"/>
                                        <DataGridTextColumn Header="Méthode" Binding="{Binding MethodePaiement}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                        
                        <Border x:Name="FormPaiement" Grid.Row="1" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}" IsEnabled="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource GoldColor}" CornerRadius="12,12,0,0" Padding="15,0">
                                    <TextBlock Text="➕ Nouveau Paiement" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="15">
                                    <TextBlock Text="Montant (€):" FontWeight="SemiBold"/>
                                    <TextBox x:Name="txtPaiementMontant" Margin="0,5,0,10"/>
                                    <TextBlock Text="Méthode:" FontWeight="SemiBold"/>
                                    <ComboBox x:Name="cmbMethodePaiement" Margin="0,5,0,15">
                                        <ComboBoxItem Content="Carte Bancaire" IsSelected="True"/>
                                        <ComboBoxItem Content="Espèces"/>
                                        <ComboBoxItem Content="Virement"/>
                                        <ComboBoxItem Content="Chèque"/>
                                    </ComboBox>
                                    <Button Content="💰 Enregistrer" Margin="0,5" Click="btnAjouterPaiement_Click" Background="#059669"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        </Grid>
    </Grid>
</Window>