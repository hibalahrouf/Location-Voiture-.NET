<Window x:Class="LocationVoiture.BackOffice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Back-Office Premium - Location de Voitures" 
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        Loaded="Window_Loaded"
        Background="#f4f6f8"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="CanResize"
        xmlns:local="clr-namespace:LocationVoiture.BackOffice">

    <Window.Resources>
        <!-- ===== MODERN LIGHT THEME COLORS ===== -->
        <SolidColorBrush x:Key="PrimaryBackground" Color="#f4f6f8"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#ffffff"/>
        <SolidColorBrush x:Key="NightBlue" Color="#0B1F3F"/>
        <SolidColorBrush x:Key="NightBlueLight" Color="#1a3a5c"/>
        <SolidColorBrush x:Key="GoldColor" Color="#B8860B"/>
        <SolidColorBrush x:Key="GoldLight" Color="#d4a528"/>
        <SolidColorBrush x:Key="TextDark" Color="#1a202c"/>
        <SolidColorBrush x:Key="TextWhite" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748b"/>
        <SolidColorBrush x:Key="BorderColor" Color="#e2e8f0"/>
        <SolidColorBrush x:Key="RowAlt" Color="#f8fafc"/>
        <SolidColorBrush x:Key="RowHover" Color="#fef3c7"/>
        
        <!-- ===== SHADOW EFFECT ===== -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.08" Color="#0B1F3F"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#0B1F3F"/>

        <!-- ===== TAB ITEM STYLE ===== -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" BorderThickness="0,0,0,3" BorderBrush="Transparent" 
                                Background="{TemplateBinding Background}" Padding="18,12" CornerRadius="8,8,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" 
                                              HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource GoldColor}"/>
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SecondaryBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource NightBlue}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#f1f5f9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== TEXTBLOCK STYLE ===== -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>

        <!-- ===== TEXTBOX STYLE ===== -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource GoldColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource GoldColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ===== COMBOBOX STYLE ===== -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ===== DATAGRID STYLE ===== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="RowBackground" Value="{DynamicResource SecondaryBackground}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource RowAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource NightBlue}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="BorderBrush" Value="{StaticResource NightBlueLight}"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource RowHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#dbeafe"/>
                                <Setter Property="Foreground" Value="{StaticResource NightBlue}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource NightBlue}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== BUTTON STYLE ===== -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GoldColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextWhite}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource GoldLight}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#a67c00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== CHECKBOX STYLE ===== -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <!-- ===== DATEPICKER STYLE ===== -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- ===== LISTBOX STYLE ===== -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

    </Window.Resources>

    <Grid x:Name="MainGrid" Background="#f4f6f8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- ===== LEFT SIDEBAR ===== -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource NightBlue}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.15" Color="#000" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Logo Section -->
                <Border Grid.Row="0" Padding="16,15">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource GoldColor}" CornerRadius="8" Padding="8,6" Margin="0,0,10,0">
                            <TextBlock Text="🚗" FontSize="18" Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="LuxeCar" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0"/>
                            <TextBlock Text="Back-Office" FontSize="10" Foreground="#94a3b8" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Navigation Menu -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,0">
                    <StackPanel>
                        <TextBlock Text="NAVIGATION" FontSize="9" Foreground="#64748b" FontWeight="Bold" Margin="12,8,0,8"/>
                        
                        <Button x:Name="NavDashboard" Content="📊  Tableau de Bord" Click="NavDashboard_Click" Style="{x:Null}" Background="Transparent" Foreground="White" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavMessages" Content="✉️  Messages Contact" Click="NavMessages_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavClients" Content="👥  Clients" Click="NavClients_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavVehicules" Content="🚗  Véhicules" Click="NavVehicules_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavLocations" Content="📋  Locations" Click="NavLocations_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavTypes" Content="🏷️  Types" Click="NavTypes_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavTarifs" Content="💰  Tarifs" Click="NavTarifs_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavEmployes" Content="👔  Employés" Click="NavEmployes_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavEntretiens" Content="🔧  Entretiens" Click="NavEntretiens_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                        <Button x:Name="NavPaiements" Content="💳  Paiements" Click="NavPaiements_Click" Style="{x:Null}" Background="Transparent" Foreground="#94a3b8" HorizontalContentAlignment="Left" Padding="14,10" Margin="4,2" FontSize="13" Cursor="Hand" BorderThickness="0"/>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Footer -->
                <Border Grid.Row="2" Padding="16,12" BorderThickness="0,1,0,0" BorderBrush="#1e3a5f">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Ellipse Width="8" Height="8" Fill="#22c55e" Margin="0,0,8,0"/>
                            <TextBlock Text="Connecté" FontSize="11" Foreground="#94a3b8"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☀️" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ToggleButton x:Name="ThemeToggle" Click="ThemeToggle_Click" Width="36" Height="18" Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="track" Background="#334155" CornerRadius="9" Width="36" Height="18">
                                            <Border x:Name="thumb" Background="{StaticResource GoldColor}" Width="14" Height="14" CornerRadius="7" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="track" Property="Background" Value="{StaticResource GoldColor}"/>
                                                <Setter TargetName="thumb" Property="Background" Value="White"/>
                                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBlock Text="🌙" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- ===== MAIN CONTENT AREA ===== -->
        <Grid x:Name="ContentGrid" Grid.Column="1" Background="#f4f6f8">
            <!-- Header Bar -->
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Border x:Name="HeaderBar" Grid.Row="0" Background="White" BorderThickness="0,0,0,1" BorderBrush="#e2e8f0" Padding="20,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ToggleSidebarBtn" Content="☰" Click="ToggleSidebar_Click" Style="{x:Null}" Background="Transparent" Foreground="{StaticResource NightBlue}" FontSize="18" Padding="8,4" Margin="0,0,15,0" Cursor="Hand" BorderThickness="0" ToolTip="Masquer/Afficher le menu"/>
                        <TextBlock x:Name="PageTitle" Text="Tableau de Bord" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource NightBlue}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='dddd dd MMMM yyyy'}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12" xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                </Grid>
            </Border>
            
            <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0" SelectedIndex="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>


            <!-- TAB 1: DASHBOARD -->
            <TabItem Header="📊 Tableau de Bord">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Stats Cards Row 1 -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Stat Card 1: Total Clients with Circle -->
                        <Border Grid.Column="0" Background="{DynamicResource SecondaryBackground}" CornerRadius="12" Padding="20" Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Circle Progress -->
                                <Grid Grid.Column="0" Width="70" Height="70" Margin="0,0,15,0">
                                    <Ellipse Stroke="#e2e8f0" StrokeThickness="6" Fill="Transparent"/>
                                    <Ellipse x:Name="CircleClients" Stroke="{StaticResource GoldColor}" StrokeThickness="6" Fill="Transparent" StrokeDashArray="1 1" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtTotalClients" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource GoldColor}"/>
                                    <TextBlock Text="Clients inscrits" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Stat Card 2: Total Vehicles with Circle -->
                        <Border Grid.Column="1" Background="{DynamicResource SecondaryBackground}" CornerRadius="12" Padding="20" Margin="5,0" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="70" Height="70" Margin="0,0,15,0">
                                    <Ellipse Stroke="#e2e8f0" StrokeThickness="6" Fill="Transparent"/>
                                    <Ellipse x:Name="CircleVehicules" Stroke="#22c55e" StrokeThickness="6" Fill="Transparent" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock Text="🚗" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtTotalVehicules" Text="0" FontSize="32" FontWeight="Bold" Foreground="#22c55e"/>
                                    <TextBlock Text="Véhicules" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Stat Card 3: Active Locations with Circle -->
                        <Border Grid.Column="2" Background="{DynamicResource SecondaryBackground}" CornerRadius="12" Padding="20" Margin="5,0" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="70" Height="70" Margin="0,0,15,0">
                                    <Ellipse Stroke="#e2e8f0" StrokeThickness="6" Fill="Transparent"/>
                                    <Ellipse x:Name="CircleLocations" Stroke="#3b82f6" StrokeThickness="6" Fill="Transparent" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock Text="📋" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtTotalLocations" Text="0" FontSize="32" FontWeight="Bold" Foreground="#3b82f6"/>
                                    <TextBlock Text="Locations" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Stat Card 4: Revenue with Circle -->
                        <Border Grid.Column="3" Background="{DynamicResource SecondaryBackground}" CornerRadius="12" Padding="20" Margin="10,0,0,0" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="70" Height="70" Margin="0,0,15,0">
                                    <Ellipse Stroke="#e2e8f0" StrokeThickness="6" Fill="Transparent"/>
                                    <Ellipse x:Name="CircleRevenu" Stroke="#f59e0b" StrokeThickness="6" Fill="Transparent" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <TextBlock Text="💰" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtTotalRevenu" Text="0 €" FontSize="26" FontWeight="Bold" Foreground="#f59e0b"/>
                                    <TextBlock Text="Chiffre d'affaires" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Circular Charts Row -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Active Reservations Chart -->
                        <Border Grid.Column="0" Background="{DynamicResource SecondaryBackground}" CornerRadius="12" Padding="25" Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="120" Height="120" Margin="0,0,0,15">
                                    <Ellipse Stroke="#e2e8f0" StrokeThickness="10" Fill="Transparent"/>
                                    <Ellipse x:Name="ChartReservations" Stroke="{StaticResource GoldColor}" StrokeThickness="10" Fill="Transparent" 
                                             StrokeDashArray="2.5 10" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="txtActiveReservations" Text="0" FontSize="28" FontWeight="Bold" 
                                                   Foreground="{StaticResource GoldColor}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="actives" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="📅 Réservations" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtReservationsPending" Text="0 en attente" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Available Vehicles Chart -->
                        <Border Grid.Column="1" Background="{DynamicResource SecondaryBackground}" CornerRadius="12" Padding="25" Margin="5,0" Effect="{StaticResource CardShadow}">
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="120" Height="120" Margin="0,0,0,15">
                                    <Ellipse Stroke="#e2e8f0" StrokeThickness="10" Fill="Transparent"/>
                                    <Ellipse x:Name="ChartVehiclesAvailable" Stroke="#22c55e" StrokeThickness="10" Fill="Transparent" 
                                             StrokeDashArray="3 10" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock x:Name="txtVehiclesAvailable" Text="0" FontSize="28" FontWeight="Bold" 
                                                   Foreground="#22c55e" HorizontalAlignment="Center"/>
